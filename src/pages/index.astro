---
import { AddToCalendarButton } from "add-to-calendar-button-react";
import logo from "../assets/glitchLogo.png";
import { Image } from "astro:assets";
import Skeleton, { title, location, locationFormatted, youtubeLink, donationLink } from "../layouts/Skeleton.astro";
import { Countdown } from "../components/Countdown";

---

<Skeleton>
  <main>
    <Image class="logo" src={logo} alt="YCF 26 Logo" />
    <h1>{title.toUpperCase()}</h1>
    <Countdown client:only="react" date={new Date("2026-06-27T12:00:00Z")} />
    <p class="date">27/06/26 - 13:00</p>
    <p class="address">{locationFormatted}</p>
    <AddToCalendarButton client:only="react"
        label="Add to Calendar"
        name={title}
        options="'Apple','Google'"
        location={location}
        startDate="2026-06-27"
        endDate="2026-06-27"
        startTime="12:00"
        endTime="14:00"
        timeZone="UTC"
        options="'Apple','Google','iCal','Outlook.com','Yahoo'"
      ></AddToCalendarButton>
      <div class="donate-button">
        <a href={donationLink} class="donate-text">Donate Here!</a>
      </div>
      <p>Can't make it? Don't worry</p>
      <div class="youtube-button">
        <svg class="yt-icon" viewBox="0 0 24 24" fill="currentColor">
          <path d="M21.58 7.19a2.76 2.76 0 0 0-1.94-1.95C18 5 12 5 12 5s-6 0-7.64.24A2.76 2.76 0 0 0 2.42 7.19 28.88 28.88 0 0 0 2 12a28.88 28.88 0 0 0 .42 4.81 2.76 2.76 0 0 0 1.94 1.95C6 19 12 19 12 19s6 0 7.64-.24a2.76 2.76 0 0 0 1.94-1.95A28.88 28.88 0 0 0 22 12a28.88 28.88 0 0 0-.42-4.81zM10 15V9l5.2 3z"/>
        </svg>
        <a href={youtubeLink} class="youtube-text">YouTube</a>
      </div>
      <p>The match will be shown live</p>
      <p>Follow us:</p>
      
      <div class="social-icons">
  <a href="https://www.facebook.com/profile.php?id=61582767508163" target="_blank" rel="noopener" aria-label="Facebook">
    <svg viewBox="0 0 512 512" preserveAspectRatio="xMidYMid meet">
      <title>Facebook social icon</title>
      <path d="M211.9 197.4h-36.7v59.9h36.7V433.1h70.5V256.5h49.2l5.2-59.1h-54.4c0 0 0-22.1 0-33.7 0-13.9 2.8-19.5 16.3-19.5 10.9 0 38.2 0 38.2 0V82.9c0 0-40.2 0-48.8 0 -52.5 0-76.1 23.1-76.1 67.3C211.9 188.8 211.9 197.4 211.9 197.4z"/>
    </svg>
  </a>
  <a href="https://www.instagram.com/ymorzincupfinal/" target="_blank" rel="noopener" aria-label="Instagram">
    <svg viewBox="0 0 512 512" preserveAspectRatio="xMidYMid meet">
      <title>Instagram social icon</title>
      <path d="M256 109.3c47.8 0 53.4 0.2 72.3 1 17.4 0.8 26.9 3.7 33.2 6.2 8.4 3.2 14.3 7.1 20.6 13.4 6.3 6.3 10.1 12.2 13.4 20.6 2.5 6.3 5.4 15.8 6.2 33.2 0.9 18.9 1 24.5 1 72.3s-0.2 53.4-1 72.3c-0.8 17.4-3.7 26.9-6.2 33.2 -3.2 8.4-7.1 14.3-13.4 20.6 -6.3 6.3-12.2 10.1-20.6 13.4 -6.3 2.5-15.8 5.4-33.2 6.2 -18.9 0.9-24.5 1-72.3 1s-53.4-0.2-72.3-1c-17.4-0.8-26.9-3.7-33.2-6.2 -8.4-3.2-14.3-7.1-20.6-13.4 -6.3-6.3-10.1-12.2-13.4-20.6 -2.5-6.3-5.4-15.8-6.2-33.2 -0.9-18.9-1-24.5-1-72.3s0.2-53.4 1-72.3c0.8-17.4 3.7-26.9 6.2-33.2 3.2-8.4 7.1-14.3 13.4-20.6 6.3-6.3 12.2-10.1 20.6-13.4 6.3-2.5 15.8-5.4 33.2-6.2C202.6 109.5 208.2 109.3 256 109.3M256 77.1c-48.6 0-54.7 0.2-73.8 1.1 -19 0.9-32.1 3.9-43.4 8.3 -11.8 4.6-21.7 10.7-31.7 20.6 -9.9 9.9-16.1 19.9-20.6 31.7 -4.4 11.4-7.4 24.4-8.3 43.4 -0.9 19.1-1.1 25.2-1.1 73.8 0 48.6 0.2 54.7 1.1 73.8 0.9 19 3.9 32.1 8.3 43.4 4.6 11.8 10.7 21.7 20.6 31.7 9.9 9.9 19.9 16.1 31.7 20.6 11.4 4.4 24.4 7.4 43.4 8.3 19.1 0.9 25.2 1.1 73.8 1.1s54.7-0.2 73.8-1.1c19-0.9 32.1-3.9 43.4-8.3 11.8-4.6 21.7-10.7 31.7-20.6 9.9-9.9 16.1-19.9 20.6-31.7 4.4-11.4 7.4-24.4 8.3-43.4 0.9-19.1 1.1-25.2 1.1-73.8s-0.2-54.7-1.1-73.8c-0.9-19-3.9-32.1-8.3-43.4 -4.6-11.8-10.7-21.7-20.6-31.7 -9.9-9.9-19.9-16.1-31.7-20.6 -11.4-4.4-24.4-7.4-43.4-8.3C310.7 77.3 304.6 77.1 256 77.1L256 77.1z"/>
      <path d="M256 164.1c-50.7 0-91.9 41.1-91.9 91.9s41.1 91.9 91.9 91.9 91.9-41.1 91.9-91.9S306.7 164.1 256 164.1zM256 315.6c-32.9 0-59.6-26.7-59.6-59.6s26.7-59.6 59.6-59.6 59.6 26.7 59.6 59.6S288.9 315.6 256 315.6z"/>
      <circle cx="351.5" cy="160.5" r="21.5"/>
    </svg>
  </a>
</div>
  </main>
</Skeleton>

<style>
  main {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: start;
    text-align: center;
    gap: 1rem;
  }

  .logo {
    max-width: 20%;
    height: auto;
    filter: drop-shadow(0 0 15px rgba(27, 101, 158, 0.21));
  }

  h1 {
    font-size: clamp(2rem, 8vw, 5rem);
    text-shadow: 0 0 15px rgba(30, 128, 203, 0.361);
    
    font-weight: bold;
    color: #328fe1;
  }

  p {
    max-width: 60%;
    font-size: clamp(1rem, 4vw, 2rem);
  }

  .date {
    font-size: clamp(2.3rem, 4vw, 4rem);
    font-family: 'Roboto', sans-serif;
    font-weight: bold;
    color: #328fe1;
  }

  .address {
    font-style: italic;
    font-size: clamp(0.7rem, 4vw, 1.2rem);
    max-width: 25%;
  }

  .donate-text {
    text-decoration: none;
    color: white;
    font-size: clamp(2.3rem, 4vw, 4rem);
  }

  .donate-button {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: #328fe1;
    color: #fff;
    border: none;
    border-radius: 5px;
    padding: 10px 20px;
    font-family: 'Roboto', sans-serif;
    font-weight: 500;
    letter-spacing: 0.5px;
    cursor: pointer;
    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.3);
  }

  .donate-button:hover {
    background: #550b80;
    transform: translateY(-1px);
  }

  .donate-button:active {
    transform: translateY(0);
  }

  .youtube-text {
    text-decoration: none;
    color: white;
    font-size: clamp(1.5rem, 4vw, 3.5rem);
  }

  .youtube-button {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: #FF0000;
    color: #fff;
    border: none;
    border-radius: 2px;
    padding: 10px 20px;
    font-family: 'Roboto', sans-serif;
    font-weight: 500;
    letter-spacing: 0.5px;
    cursor: pointer;
    box-shadow: 0 2px 6px rgba(255,0,0,0.3);
  }

  .youtube-button:hover {
    background: #cc0000;
    transform: translateY(-1px);
  }

  .youtube-button:active {
    transform: translateY(0);
  }

  .yt-icon { width: 20px; height: 20px; }

  .social-icons {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
  justify-content: center;
}

.social-icons a {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 36px;
  height: 36px;
  padding: 7px;
  background: linear-gradient(135deg, #2b4967 0%, #05264b 100%);
  border-radius: 12px;
  color: #ffffff;
  text-decoration: none;
  transition: transform 0.3s ease, filter 0.3s ease;
}

.social-icons a:hover {
  transform: translateY(-4px);
  filter: brightness(1.3);
}

.social-icons svg {
  width: 36px;
  height: 36px;
  display: block;
  fill: #ffffff;
}

</style>
